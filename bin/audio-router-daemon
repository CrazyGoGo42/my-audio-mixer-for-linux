#!/usr/bin/env python3
"""
Audio Router Daemon — watches for new audio streams on the default output
and asks the user which virtual sink to route them to.

Only triggers for streams NOT already on a virtual sink.
Remembers choices in WirePlumber's restore-stream database.
"""

import subprocess, json, os, time, signal, sys, re

VIRTUAL_SINKS = {"Games_Audio", "Discord_Audio", "Music_Audio", "Browser_Audio"}
RESTORE_FILE = os.path.expanduser("~/.local/state/wireplumber/restore-stream")
PID_FILE = "/tmp/audio-router-daemon.pid"

# Apps to silently ignore (internal/system streams)
IGNORE_APPS = {"audio-osd", "speech-dispatcher-dummy", "paplay", "libcanberra",
               "GNOME Volume Control Media Keys", "gnome-shell", "Mutter",
               "easyeffects", "gnome-pomodoro", "xdg-desktop-portal"}
IGNORE_NODES = {"Games_Audio_out", "Discord_Audio_out", "Music_Audio_out",
                "Browser_Audio_out", "Desktop_Audio_out"}

# Known routing rules — auto-route these without asking
AUTO_ROUTE = {
    "discord": "Discord_Audio",
    "WEBRTC VoiceEngine": "Discord_Audio",
    "youtube-music": "Music_Audio",
    "youtubemusic": "Music_Audio",
    "spotify": "Music_Audio",
    "plexamp": "Music_Audio",
}
AUTO_BROWSERS = {"chrome", "chromium", "chromium-browser", "google-chrome-stable",
                 "firefox", "firefox-esr", "brave", "brave-browser",
                 "vivaldi", "vivaldi-stable", "opera", "msedge"}

# Track which sink-input indices we've already handled this session
handled = set()


def run(cmd):
    r = subprocess.run(cmd, capture_output=True, text=True, timeout=5)
    return r.stdout.strip()


def get_sink_name_by_index(idx):
    """Get the sink node.name for a pactl sink index."""
    try:
        out = run(["pactl", "list", "sinks"])
    except Exception:
        return None
    current_idx = None
    for line in out.split("\n"):
        line = line.strip()
        if line.startswith("Sink #"):
            current_idx = line.split("#")[1]
        elif "node.name" in line and "=" in line and current_idx == str(idx):
            return line.split("=")[1].strip().strip('"')
    return None


def get_new_streams():
    """Find sink-inputs that are on default/easyeffects sink (not on a virtual sink)."""
    try:
        out = run(["pactl", "list", "sink-inputs"])
    except Exception:
        return []

    streams = []
    current = {}

    for line in out.split("\n"):
        line_s = line.strip()
        if line_s.startswith("Sink Input #"):
            if current:
                streams.append(current)
            current = {"idx": line_s.split("#")[1], "props": {}, "sink": None}
        elif line_s.startswith("Sink:") and current:
            current["sink"] = line_s.split(":")[1].strip()
        elif "=" in line_s and current:
            key, _, val = line_s.partition("=")
            current["props"][key.strip()] = val.strip().strip('"')

    if current:
        streams.append(current)

    result = []
    for s in streams:
        idx = s["idx"]
        if idx in handled:
            continue

        node_name = s["props"].get("node.name", "")
        app_name = s["props"].get("application.name", "")
        binary = s["props"].get("application.process.binary", "")

        # Skip internal/system streams
        if node_name in IGNORE_NODES:
            handled.add(idx)
            continue
        if app_name in IGNORE_APPS or binary in IGNORE_APPS:
            handled.add(idx)
            continue

        # Check if already on a virtual sink
        sink_idx = s.get("sink")
        if sink_idx:
            sink_name = get_sink_name_by_index(sink_idx)
            if sink_name in VIRTUAL_SINKS:
                handled.add(idx)
                continue

        display = app_name or binary or node_name
        if not display or display.startswith("PipeWire"):
            handled.add(idx)
            continue

        result.append({
            "idx": idx,
            "app": app_name,
            "binary": binary,
            "node": node_name,
            "display": display,
        })

    return result


def get_auto_target(stream):
    """Check if this stream matches an auto-route rule."""
    binary = stream["binary"].lower()
    app = stream["app"]

    if binary in AUTO_ROUTE:
        return AUTO_ROUTE[binary]
    if app in AUTO_ROUTE:
        return AUTO_ROUTE[app]
    if binary in AUTO_BROWSERS:
        return "Browser_Audio"
    return None


def ask_user(stream):
    """Show a zenity dialog asking which channel to route the app to."""
    display = stream["display"]
    try:
        r = subprocess.run([
            "zenity", "--list",
            "--title", f"Route: {display}",
            "--text", f"<b>{display}</b> is playing audio on the default output.\nWhich channel should it use?",
            "--column", "Sink", "--column", "Channel",
            "--hide-column=1",
            "Games_Audio", "Games",
            "Discord_Audio", "Discord",
            "Music_Audio", "Music",
            "Browser_Audio", "Browser",
            "", "Leave on default (don't route)",
            "--width", "340", "--height", "300",
        ], capture_output=True, text=True, timeout=30)

        if r.returncode != 0:
            return None
        choice = r.stdout.strip().rstrip("|")
        return choice if choice else None
    except subprocess.TimeoutExpired:
        return None
    except Exception:
        return None


def route_stream(stream, target_sink):
    """Move the stream to the target sink and persist in WirePlumber."""
    try:
        r = subprocess.run(
            ["pactl", "move-sink-input", stream["idx"], target_sink],
            capture_output=True, text=True
        )
        if r.returncode == 0:
            persist_target(stream["app"] or stream["display"], target_sink)
            notify(f"Routed {stream['display']} → {target_sink.replace('_Audio', '')}")
            return True
    except Exception:
        pass
    return False


def persist_target(app_name, target_sink):
    """Write routing target into WirePlumber's restore-stream database."""
    if not os.path.isfile(RESTORE_FILE):
        return
    escaped = app_name.replace("\\", "\\\\").replace(" ", "\\s").replace("[", "\\o").replace("]", "\\c")
    key = f"Output/Audio:application.name:{escaped}"
    target_line = f"{key}:target={target_sink}\n"

    lines = open(RESTORE_FILE).readlines()
    target_key = f"{key}:target="
    found = False
    new_lines = []
    for line in lines:
        if line.startswith(target_key):
            new_lines.append(target_line)
            found = True
        else:
            new_lines.append(line)
    if not found:
        volume_key = f"{key}:volume="
        inserted = False
        final = []
        for line in new_lines:
            final.append(line)
            if not inserted and line.startswith(volume_key):
                final.append(target_line)
                inserted = True
        if not inserted:
            final.append(f"{key}:channelMap=FL;FR;\n")
            final.append(f"{key}:channelVolumes=1.0;1.0;\n")
            final.append(f"{key}:mute=false\n")
            final.append(target_line)
            final.append(f"{key}:volume=1.0\n")
        new_lines = final
    open(RESTORE_FILE, "w").writelines(new_lines)


def notify(msg):
    try:
        subprocess.Popen(["notify-send", "-t", "3000", "Audio Router", msg],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass


def cleanup(signum=None, frame=None):
    try:
        os.unlink(PID_FILE)
    except OSError:
        pass
    sys.exit(0)


def main():
    # Write PID file
    signal.signal(signal.SIGTERM, cleanup)
    signal.signal(signal.SIGINT, cleanup)
    with open(PID_FILE, "w") as f:
        f.write(str(os.getpid()))

    # Use pactl subscribe to watch for new sink-inputs
    proc = subprocess.Popen(
        ["pactl", "subscribe"],
        stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, text=True
    )

    # Small delay on startup to skip existing streams
    time.sleep(2)
    # Mark all current streams as handled
    for s in get_new_streams():
        handled.add(s["idx"])

    for line in proc.stdout:
        if "'new'" not in line or "sink-input" not in line:
            continue

        # Small delay to let the stream fully register
        time.sleep(0.5)

        for stream in get_new_streams():
            handled.add(stream["idx"])

            # Check auto-route rules first
            auto_target = get_auto_target(stream)
            if auto_target:
                route_stream(stream, auto_target)
                continue

            # Ask the user
            target = ask_user(stream)
            if target:
                route_stream(stream, target)

    cleanup()


if __name__ == "__main__":
    main()
